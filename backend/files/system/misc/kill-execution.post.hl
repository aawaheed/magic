
/*
 * Kills the specified execution context.
 * Useful for killing long lasting processes, such as chat requests with multiple turns, etc.
 */
.arguments
   execution_id:string

// Sanity checking invocation
validators.mandatory:x:@.arguments/*/execution_id

// Making sure user is authorized to access endpoint.
auth.ticket.verify:root

// Killing execution context.
execution.kill:x:@.arguments/*/execution_id

// Returning success to caller.
return
   message:Execution successfully cancelled.
