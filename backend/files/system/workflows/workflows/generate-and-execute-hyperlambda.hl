
/*
 * Uses the Hyperlambda Generator to generate code matching the prompt and executing it.
 */
.arguments

   // Mandatory argument describing the Hyperlambda code you want to generate.
   prompt:string

// Ensuring we catch exceptions.
try
   add:x:./*/http.post/*/payload
      get-nodes:x:@.arguments/*/prompt
   http.post:"https://ainiro.io/magic/modules/hyperlambda-generator/chat"
      convert:true
      timeout:30
      payload

   // Sanity checking invocation
   if
      and
         not
            mte:x:@http.post
               .:int:200
         not
            lt:x:@http.post
               .:int:300
      .lambda

         // Something went wrong
         lambda2hyper:x:@http.post
         throw:x:-
            public:bool:true
            status:int:400

   // Executing code and returning the result.
   if
      auth.ticket.in-role:root
      .lambda

         // User is root, executing "whatever".
         hyper2lambda:x:@http.post/*/content/*/result
         invoke:x:-
         if
            not-null:x:@invoke
            .lambda
               return-value:x:@invoke
         else-if
            exists:x:@invoke/*
            .lambda
               return-nodes:x:@invoke/*
         return
            message:Code did not return anything!

   else

      /*
       * User is not root, restricting execution to valid slots,
       * and restricting execution time to 15 seconds.
       */
      execution.timeout:15

      // Adding lambda object to [whitelist] invocation.
      add:x:./*/whitelist/*/.lambda
         hyper2lambda:x:@http.post/*/content/*/result

      // Executing lambda object, and returning the result.
      whitelist
         vocabulary
            add
            and
            apply
            case
            compose
            convert
            csv2lambda
            default
            else
            else-if
            eq
            exists
            for-each
            format
            get-count
            get-first-value
            get-name
            get-nodes
            get-value
            html-decode
            html2lambda
            html2markdown
            hyper2lambda
            if
            include
            insert-after
            insert-before
            json2lambda
            json2yaml
            lambda2csv
            lambda2html
            lambda2hyper
            lambda2json
            lambda2xml
            lambda2yaml
            lt
            lte
            markdown2html
            mt
            mte
            neq
            not
            not-exists
            not-null
            null
            or
            remove-nodes
            return
            return-nodes
            return-value
            set-name
            set-value
            set-x
            sleep
            sort
            switch
            throw
            time
            try
            type
            types
            unwrap
            version
            vocabulary
            while
            xml2lambda
            yaml2json
            yaml2lambda
            yield
            auth.ticket.get
            auth.ticket.in-role
            auth.ticket.verify
            auth.token.verify
            crypto.aes.decrypt
            crypto.aes.encrypt
            crypto.decrypt
            crypto.encrypt
            crypto.fingerprint
            crypto.get-key
            crypto.hash
            crypto.hash.md5
            crypto.hash.sha1
            crypto.hash.sha256
            crypto.hash.sha384
            crypto.hash.sha512
            crypto.password.hash
            crypto.password.verify
            crypto.random
            crypto.random.int
            crypto.rsa.create-key
            crypto.rsa.decrypt
            crypto.rsa.encrypt
            crypto.rsa.sign
            crypto.rsa.verify
            crypto.seed
            crypto.sign
            crypto.verify
            date.format
            date.from-unix
            date.max
            date.min
            date.now
            date.unix
            guid.new
            http.delete
            http.get
            math.abs
            math.add
            math.ceil
            math.cos
            math.decrement
            math.divide
            math.floor
            math.increment
            math.max
            math.min
            math.modulo
            math.multiply
            math.random
            math.round
            math.sin
            math.sqrt
            math.subtract
            mime.create
            mime.parse
            openai.tokenize
            request.cookies.get
            request.cookies.list
            request.headers.get
            request.headers.list
            request.host
            request.ip
            request.scheme
            request.url
            request.verb
            response.cookies.set
            response.headers.set
            response.status.set
            server.ip
            slots.vocabulary
            strings.builder
            strings.builder.append
            strings.byte-count
            strings.capitalize
            strings.concat
            strings.contains
            strings.ends-with
            strings.html-decode
            strings.html-encode
            strings.join
            strings.length
            strings.matches
            strings.mixin
            strings.regex-replace
            strings.replace
            strings.replace-not-of
            strings.split
            strings.starts-with
            strings.substring
            strings.to-lower
            strings.to-upper
            strings.trim
            strings.trim-end
            strings.trim-start
            strings.url-decode
            strings.url-encode
            time.format
            time.total-milliseconds
            validators.date
            validators.default
            validators.email
            validators.enum
            validators.integer
            validators.mandatory
            validators.recaptcha
            validators.regex
            validators.string
            validators.url
         .lambda

      // Returning result to caller.
      if
         not-null:x:@whitelist
         .lambda
            return-value:x:@whitelist
      else-if
         exists:x:@whitelist/*
         .lambda
            return-nodes:x:@whitelist/*
      return
         message:Code did not return anything!

.catch
   lambda2hyper:x:../*
   log.error:x:@.arguments/*/message
      stack:x:@lambda2hyper
   throw:x:@.arguments/*/message
      status:int:502
      public:bool:true
