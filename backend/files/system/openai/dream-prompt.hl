
/*
 * Compresses specified session by invoking OpenAI telling it to list all facts only.
 */
.arguments
   session:string
   items:*

// Calculating how many tokens context used to hold.
lambda2json:x:@.arguments/*/items/*
.original-tokens
set-value:x:-
   openai.tokenize:x:@lambda2json

// Signaling frontend.
strings.concat
   .:"Dream compressing context, current size; "
   format:x:@.original-tokens
      pattern:"{0:N0}"
sockets.signal:x:@.arguments/*/session
   args
      type:floating_message
      floating_message:x:@strings.concat
      floating_state:success

// Extracting system message.
.sm
set-value:x:-
   io.file.load:/system/openai/dream-prompt-system-message.md

// Getting token
.token
set-value:x:@.token
   strings.concat
      .:"Bearer "
      config.get:"magic:openai:key"

// Parametrizing HTTP invocation
add:x:./*/http.post/*/payload/*/input
   get-nodes:x:@.arguments/*/items/*
unwrap:x:+/*/*/*
insert-before:x:./*/http.post/*/payload/*/input/0
   .
      .
         role:system
         content:x:@.sm

// Invoking OpenAI to compress working memory.
http.post:"https://api.openai.com/v1/responses"
   convert:bool:true
   timeout:180
   headers
      Authorization:x:@.token
      Content-Type:application/json
      Connection:close
   payload
      model:gpt-4.1-mini
      max_output_tokens:int:2500
      temperature:decimal:0.3
      input

// Sanity checking result
if
   and
      mte:x:@http.post
         .:int:200
      lt:x:@http.post
         .:int:300
      or
         exists:x:@http.post/*/content/*/output/*/*/type/=message/./*/content/*/*/type/=output_text/./*/text
         exists:x:@http.post/*/content/*/output/0/*/content/0/*/text
   .lambda

      // Making sure we return new session items
      .summary
      set-value:x:@.summary
         get-first-value
            get-value:x:@http.post/*/content/*/output/*/*/type/=message/./*/content/*/*/type/=output_text/./*/text
            get-value:x:@http.post/*/content/*/output/0/*/content/0/*/text
      set-value:x:@.summary
         strings.concat
            .:"COMPRESSED CONTEXT; "
            strings.trim:x:@.summary
      .session
      unwrap:x:+/*/*/*
      add:x:@.session
         .
            .
               role:system
               content:x:@.summary

      // Removing all but the last items convo roundtrip
      .cont:bool:true
      while:x:@.cont
         insert-after:x:@.session/0
            get-nodes:x:@.arguments/*/items/0/-
         if
            eq:x:@.arguments/*/items/0/-/*/role
               .:user
            .lambda
               set-value:x:@.cont
                  .:bool:false
         remove-nodes:x:@.arguments/*/items/0/-

      // Logging.
      log.info:Dream compressions of context succeeded
         session:x:@.arguments/*/session

      // Calculating how many tokens context holds now.
      lambda2json:x:@.session/*
      .new-tokens
      set-value:x:-
         openai.tokenize:x:@lambda2json

      // Signaling frontend.
      strings.concat
         .:"Dream compressions succeeded - Current size; "
         format:x:@.new-tokens
            pattern:"{0:N0}"
      sockets.signal:x:@.arguments/*/session
         args
            type:floating_message
            floating_message:x:@strings.concat
            floating_state:success
      return-nodes:x:@.session/*
