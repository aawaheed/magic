/*
 * Uses a headless browser to navigate to ainiro.io and capture a screenshot
 */
puppeteer.connect
   executable-path:/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
puppeteer.goto:x:@puppeteer.connect
   url:"https://ainiro.io"
puppeteer.screenshot:x:@puppeteer.connect
   filename:/etc/tmp/ainiro.png
   full-page:true
puppeteer.close:x:@puppeteer.connect
