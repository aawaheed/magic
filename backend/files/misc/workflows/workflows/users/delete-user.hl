
/*
 * Deletes the specified user
 * 
 * Returns success if deletion was successful.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory
   username:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/username

// Opening database connection.
data.connect:magic

   // Deleting our user.
   data.delete
      table:users
      where
         and
            username.eq:x:@.arguments/*/username

   // Checking if we deleted something
   if
      eq:x:@data.delete
         .:int:0
      .lambda

         // Oops ...!!
         throw:User not found
            public:bool:true
            status:int:404

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:User successfully deleted
      floating_state:success

// Returning success
return
   result:success
