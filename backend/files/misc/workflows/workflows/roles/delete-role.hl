
/*
 * Deletes the specified role
 * 
 * Returns success if deletion was successful.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory
   name:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/name

// Opening database connection.
data.connect:magic

   // Deleting our role.
   data.delete
      table:roles
      where
         and
            name.eq:x:@.arguments/*/name

   // Checking if we deleted something
   if
      eq:x:@data.delete
         .:int:0
      .lambda

         // Oops ...!!
         throw:Role not found
            public:bool:true
            status:int:404

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:Role successfully deleted
      floating_state:success

// Returning success
return
   result:success
