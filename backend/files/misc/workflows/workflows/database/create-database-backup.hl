
/*
 * Executable Hyperlambda file that create a backup of an existing SQLite database.
 * 
 * Pass in the name of the database as [database].
 */
.arguments

   // Mandatory name of database. Can only contain lover case characters, '_', '-', and 0-9
   database:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/database
validators.regex:x:@.arguments/*/database
   regex:^[a-z0-9_-]+$

// Verifying database exists.
strings.concat
   .:/data/
   get-value:x:@.arguments/*/database
   .:.db
if
   not
      io.file.exists:x:@strings.concat
   .lambda
      throw:Database does not exists
         public:bool:true
         status:400

// Create our backup.
date.now
strings.concat
   get-value:x:@.arguments/*/database
   .:.
   date.format:x:@date.now
      format:yyyy-MM-ddTHH-mm-ss
   .:.
   .:backup
data.connect:x:@.arguments/*/database
   sqlite.backup:x:@strings.concat
   sqlite.connections.flush
   log.info:Created backup of database

// Returning success to caller.
strings.concat
   .:/data/
   get-value:x:@strings.concat/@strings.concat
yield
   backup_filename:x:@strings.concat
