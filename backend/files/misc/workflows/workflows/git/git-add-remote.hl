
/*
 * Adds a remote to the specified Git project.
 * 
 * Arguments:
 * 
 * - [path] is mandatory folder of where repo is locally on dics.
 * - [message] is the mandatory message.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory folder to where Git repo is locally on dics.
   path:string

   // Mandatory URL for upstream.
   url:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/path
validators.mandatory:x:@.arguments/*/url
validators.default:x:@.arguments
   name:origin

// Sanity checking invocation.
if
   and
      not
         strings.starts-with:x:@.arguments/*/path
            .:/modules/
      not
         strings.starts-with:x:@.arguments/*/path
            .:/etc/
   .lambda
      throw:"Git repos must be in folders inside of either '/etc/' or '/modules/'"

// Parametrising slot
add:x:./*/git.remote.add
   get-nodes:x:@.arguments/*/url
   get-nodes:x:@.arguments/*/name

// Invoking slot.
git.remote.add:x:@.arguments/*/path

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:Git remote successfully added
      floating_state:success

// Returning success
yield
   result:success
