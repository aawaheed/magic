
/*
 * Deletes an existing GitHub repository
 * 
 * Arguments:
 * 
 * - [name] is mandatory name of GitHub project.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory name of repository.
   name:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/name

// Invoking slot.
github.repo.delete:x:@.arguments/*/name

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:GitHub repo successfully deleted
      floating_state:success

// Returning success
yield
   result:success
