
/*
 * Downloads the specified web file.
 * 
 * Arguments:
 * 
 * - [file] being mandatory relative file path.
 */
.arguments

   // Mandatory argument specified by the framework being the SignalR session.
   _session:string

   // Mandatory relative path of file to download
   filename:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/filename

// Prepending slash unless specified by caller.
if
   not
      strings.starts-with:x:@.arguments/*/filename
         .:/
   .lambda
      set-value:x:@.arguments/*/filename
         strings.concat
            .:/
            get-value:x:@.arguments/*/filename

// Verifying that file exists.
if
   not
      io.file.exists:x:@.arguments/*/filename
   .lambda

      // Oops ...!!
      throw:File does not exist
         public:bool:true
         status:int:404

// We'll need a token for the download URL.
auth.ticket.create
   username:service
   roles
      .:root

/*
 * Signaling frontend.
 * This will create a download link in the frontend dashboard.
 */
sockets.signal:x:@.arguments/*/_session
   roles:root
   args
      type:download_file
      filename:x:@.arguments/*/filename
      ticket:x:@auth.ticket.create

// Returning success
return
   message:Click the button to download the file
