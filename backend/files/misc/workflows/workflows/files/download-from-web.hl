
/*
 * Downloads the specified [url] and saves to the specified [filename].
 * 
 * [filename] is the absolute path for where to save the file.
 * 
 * All arguments are mandatory, and user must be root to execute
 */
.arguments

   // URL to document caller wants to download.
   url:string

   // Mandatory filename of where to save the result.
   filename:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/url
validators.mandatory:x:@.arguments/*/filename

// Prepending slash unless specified by caller.
if
   not
      strings.starts-with:x:@.arguments/*/filename
         .:/
   .lambda
      set-value:x:@.arguments/*/filename
         strings.concat
            .:/
            get-value:x:@.arguments/*/filename

// Making sure we do not overwrite system files.
if
   not
      or
         strings.starts-with:x:@.arguments/*/filename
            .:/etc/
         strings.starts-with:x:@.arguments/*/filename
            .:/modules/
   .lambda
      throw:"You can only save files into the '/modules/' and '/etc/ folders'"
         status:int:400
         public:bool:true

// Retrieving file
http.get:x:@.arguments/*/url

// Saving the file on local file system.
io.file.save.binary:x:@.arguments/*/filename
   get-value:x:@http.get/*/content

// Returning success to caller.
return
   result:success
