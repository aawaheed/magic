
/*
 * Sends the specified HTML to the frontend
 * 
 * [html] is mandatory and can be any HTML
 */
.arguments

   // Mandatory argument injected by the framework, being the current session.
   _session:string

   // Mandatory argument being the HTML to send to the client.
   html:string

   // Optional filename argument serving as an alternative to above [html] argument.
   filename:string

   // Optional arguments used to replace {{placeholder}} tokens in widget HTML.
   arguments

// Making sure user is allowed to execute function.
auth.ticket.verify:root

if
   and
      exists:x:@.arguments/*/html
      exists:x:@.arguments/*/filename
   .lambda
      throw:"Supply only one of `html` or `filename`, and not both!"
         status:int:400
         public:bool:true

// Buffer for HTML.
.html
if
   and
      exists:x:@.arguments/*/html
      not-null:x:@.arguments/*/html
   .lambda
      set-value:x:@.html
         get-value:x:@.arguments/*/html

else-if

   and
      exists:x:@.arguments/*/filename
      not-null:x:@.arguments/*/filename
   .lambda
      if
         not
            io.file.exists:x:@.arguments/*/filename
         .lambda
            throw:"No [html] or [filename] argument provided, provide one of these"
               status:int:500
               public:bool:true

      // Sanity checking that this is an HTML file.
      if
         and
            not
               strings.ends-with:x:@.arguments/*/filename
                  .:.htm
            not
               strings.ends-with:x:@.arguments/*/filename
                  .:.html
         .lambda
            throw:You can only render HTML files using this function
               status:int:400
               public:bool:true

      set-value:x:@.html
         io.file.load:x:@.arguments/*/filename

// Verifying this is a valid widget.
if
   not
      strings.contains:x:@.html
         .:WIDGET_ID_UNIQUE_NUMBER
   .lambda
      throw:"Not a valid widget! No 'WIDGET_ID_UNIQUE_NUMBER' found in HTML"
         status:int:400
         public:bool:true

/*
 * Replacing all "WIDGET_ID_UNIQUE_NUMBER" strings with a CSRNG generated string to avoid duplication of HTML elements,
 * CSS selectors, and JavaScript functions.
 */
set-value:x:@.html
   strings.replace:x:@.html
      .:WIDGET_ID_UNIQUE_NUMBER
      strings.concat
         .:x
         crypto.random
            min:20
            max:20

/*
 * Replacing widget arguments such as {{name}} and {{url}} with HTML encoded values.
 */
for-each:x:@.arguments/*/arguments/*
   set-value:x:@.html
      strings.replace:x:@.html
         strings.concat
            .:{{
            get-name:x:@.dp/#
            .:}}
         strings.html-encode:x:@.dp/#

/*
 * Failing if one or more placeholders were left unresolved after replacement.
 */
strings.matches:x:@.html
   .:\{\{[a-zA-Z0-9_-]+\}\}
if
   exists:x:@strings.matches/*
   .lambda
      throw:"Missing widget arguments for one or more placeholders"
         status:int:400
         public:bool:true

/*
 * Signaling frontend.
 * This will create a download link in the frontend dashboard.
 */
sockets.signal:x:@.arguments/*/_session
   roles:root
   args
      type:render_html
      html:x:@.html

// Returning success
return
   message:HTML was successfully sent to client
