
/*
 * Creates a PDF file from the specified [html] input argument.
 * 
 * The resulting PDF file will be saved to the file specified by the [output_pdf] argument.
 */
.arguments

   // What HTML to transform to Markdown
   html:string

   // Where to save the resulting PDF
   filename:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/html
validators.mandatory:x:@.arguments/*/filename

// Prepending slash unless specified by caller.
if
   not
      strings.starts-with:x:@.arguments/*/filename
         .:/
   .lambda
      set-value:x:@.arguments/*/filename
         strings.concat
            .:/
            get-value:x:@.arguments/*/filename

// Making sure we do not overwrite system files.
if
   not
      or
         strings.starts-with:x:@.arguments/*/filename
            .:/etc/
         strings.starts-with:x:@.arguments/*/filename
            .:/modules/
   .lambda
      throw:"You can only save files to the '/modules/' and '/etc/' folders"
         status:int:400
         public:bool:true

// Converting HTML to PDF and saving to specified file.
io.file.save.binary:x:@.arguments/*/filename
   html2pdf:x:@.arguments/*/html

// Returning success to caller.
yield
   full_path:x:@.arguments/*/filename
