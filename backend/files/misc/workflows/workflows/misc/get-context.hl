
/*
 * Searches through your training snippets using RAG / VSS search for the specified query
 *
 * This function will use VSS to search through your RAG database for training snippets matching the specified [query] that are within the specified [threshold] of similarity and return the first [max_tokens] training snippets as Markdown context data.
 */
.arguments

   // Dynamically injected by the LLM.
   _type:string

   // Mandatory argument and the actual query to use when finding data from your RAG database.
   query:string

   // Optional argument and the number of tokens to return. The default value of not spcified is 4000.
   max_tokens:int

   // Optional argument being similarity distance between query and RAG records matched during search. Will default to 0.3 if not specified.
   threshold:decimal

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/_type
validators.mandatory:x:@.arguments/*/query

// Applying defaults.
validators.default:x:@.arguments
   max_tokens:int:5000
   threshold:decimal:0.3

// Checking if the caller is searching by "ID", at which point we do NOT use VSS!
if
   eq
      strings.replace-not-of:x:@.arguments/*/query
         .:abcdefghijklmnopqrstuvwxyz1234567890-
         .:
      get-value:x:@.arguments/*/query
   .lambda

      // Query contains only small letters, numbers, and '-' character.
      strings.concat
         .:%
         get-value:x:@.arguments/*/query
         .:.hl
      data.connect:magic
         data.read
            table:ml_training_snippets
            where
               and
                  meta.like:x:@strings.concat
         if
            exists:x:@data.read/*
            .lambda
               strings.concat
                  .:"# "
                  get-value:x:@data.read/0/*/prompt
                  .:"\n\n"
                  get-value:x:@data.read/0/*/completion
               yield
                  context:x:@strings.concat

set-value:x:@.arguments/*/threshold
   convert:x:@.arguments/*/threshold
      type:decimal

// Converting `max_tokens` to int to be sure.
set-value:x:@.arguments/*/max_tokens
   convert:x:@.arguments/*/max_tokens
      type:int

// Retrieving context.
execute:magic.ai.get-context
   type:x:@.arguments/*/_type
   prompt:x:@.arguments/*/query
   threshold:x:@.arguments/*/threshold
   max_tokens:x:@.arguments/*/max_tokens

// Returning result of invocation to caller.
yield
   context:x:@execute/*/context
