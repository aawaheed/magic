
/*
 * Deletes the specified [name] task.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory argument being the task to delete
   name:string

// Ensuring user is root.
auth.ticket.verify:root

// Deleting task.
tasks.delete:x:@.arguments/*/name

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:Task successfully deleted
      floating_state:success

// Returning success to caller.
return
   result:success