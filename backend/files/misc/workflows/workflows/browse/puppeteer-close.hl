/*
 * Closes an existing Puppeteer session.
 *
 * Arguments:
 * - [session_id] Session id (required)
 */
.arguments
   session_id:string

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/session_id

// Core invocation.
puppeteer.close:x:@.arguments/*/session_id

return
   result:success
