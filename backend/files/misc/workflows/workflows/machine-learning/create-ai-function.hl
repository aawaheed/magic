
/*
 * Creates an AI function for the specified [type] and [filename]
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory name of type.
   type:string

   // Mandatory prompt serving is single line description.
   prompt:string

   // Mandatory completion serving as more detailed description.
   completion:string

   // Mandatory AI function file.
   filename:string

   // Optional argument. If true, adds the AI function declaration to the system instruction.
   system_instruction:bool

// Ensuring user is root.
auth.ticket.verify:root

// Adding defaults
validators.default:x:@.arguments
   system_instruction:bool:false

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/type
validators.mandatory:x:@.arguments/*/prompt
validators.mandatory:x:@.arguments/*/completion
validators.regex:x:@.arguments/*/type
   regex:^[a-z0-9_-]+$
validators.mandatory:x:@.arguments/*/filename

// Retrieving arguments by letting another file doing the heavy lifting.
execute-file:/system/workflows/get-hyperlambda-arguments.post.hl
   path:x:@.arguments/*/filename

// Check out signature determine what it does"
.args
add:x:@.args
   get-nodes:x:@execute-file/*/args/*

// Adding function invocation declaration to completion.
.completion
set-value:x:@.completion
   strings.concat
      get-value:x:@.arguments/*/completion
      .:"\n\n___\nFUNCTION_INVOCATION["
      get-value:x:@.arguments/*/filename
      .:]

// Checking if function accepts arguments
if
   exists:x:@.args/*
   .lambda

      // Making sure we add arguments to function declaration.
      set-value:x:@.completion
         strings.concat
            get-value:x:@.completion
            .:":\n"
      .obj
      .tail:"Arguments:\n"
      for-each:x:@.args/*
         set-name:x:+/*/*
            get-value:x:@.dp/#/*/name
         add:x:@.obj
            .
               name
         switch:x:@.dp/#/*/type
            case:int
            case:long
               set-value:x:@.obj/0/-
                  .:"[NUMERIC_VALUE]"
            case:date
               set-value:x:@.obj/0/-
                  .:"[ISO_DATETIME_VALUE]"
            default
               set-value:x:@.obj/0/-
                  .:"[STRING_VALUE]"
         set-value:x:@.tail
            strings.concat
               get-value:x:@.tail
               .:"\n - ["
               get-value:x:@.dp/#/*/name
               .:"] "
               get-first-value
                  get-value:x:@.dp/#/*/description
                  .:"NO DESCRIPTION"
      lambda2json:x:@.obj/*
         format:true
      set-value:x:@.completion
         strings.concat
            get-value:x:@.completion
            get-value:x:@lambda2json
            .:"\n___"
            .:"\n\n"
            get-value:x:@.tail
      set-value:x:@.completion
         strings.trim:x:@.completion

else

   // File doesn't take arguments.
   set-value:x:@.completion
      strings.concat
         get-value:x:@.completion
         .:"\n___"

// Checking if we're to add it to the system instruction or not.
if
   neq:x:@.arguments/*/system_instruction
      .:bool:true
   .lambda

      // Creating meta value.
      .meta
      set-value:x:@.meta
         strings.concat
            .:"FUNCTION_INVOCATION ==> "
            get-value:x:@.arguments/*/filename

      // Inserting training snippet into database.
      data.connect:magic
         data.create
            table:ml_training_snippets
            values
               type:x:@.arguments/*/type
               prompt:x:@.arguments/*/prompt
               completion:x:@.completion
               meta:x:@.meta

         // Signaling frontend
         sockets.signal:x:@.arguments/*/_session
            args
               type:floating_message
               floating_message:AI function successfully created as RAG snippet
               floating_state:success

         // Returning result to caller.
         yield
            result:success
            prompt:x:@.prompt
            completion:x:@.completion
            id:x:@data.create

else

   // Adding it to the system instruction
   data.connect:magic
      data.read
         table:ml_types
         where
            and
               type.eq:x:@.arguments/*/type
      if
         not-exists:x:@data.read/*
         .lambda
            throw:No sych machine learning type
               public:bool:true
               status:int:400
      .instruction
      set-value:x:@.instruction
         strings.concat
            get-value:x:@data.read/*/*/system_message
            .:"\n\n### "
            get-value:x:@.arguments/*/prompt
            .:"\n\n"
            get-value:x:@.completion
      data.update
         table:ml_types
         where
            and
               type.eq:x:@.arguments/*/type
         values
            system_message:x:@.instruction

   // Signaling frontend
   sockets.signal:x:@.arguments/*/_session
      args
         type:floating_message
         floating_message:
         floating_state:success

