
/*
 * Adds the specified [filename] widget to the specified [type] as an HTML widget
 * with the specified [prompt].
 */
.arguments

   // Mandatory name of type.
   type:string

   // Mandatory prompt for widget
   prompt:string

   // Mandatory widget file.
   filename:string

   // Optional arguments used to replace [[placeholder]] tokens in widget HTML.
   arguments:*

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/type
validators.regex:x:@.arguments/*/type
   regex:^[a-z0-9_-]+$
validators.mandatory:x:@.arguments/*/filename

// Making sure file exists.
if
   not
      io.file.exists:x:@.arguments/*/filename
   .lambda
      throw:Widget file does not exist
         status:int:404
         public:bool:true

// Makes sure we don't try to add widgets outside of modules.
if
   not
      strings.starts-with:x:@.arguments/*/filename
         .:/modules/
   .lambda
      throw:"You can only add widgets that are inside of the /modules/ folder, where xyz is your module's name. Use fully qualitifed paths, including '/module/' and the module's name."
         status:int:400
         public:bool:true

// Creating our completion.
.args:
if
   exists:x:@.arguments/*/arguments/*
   .lambda
      set-value:x:@.args
         .:"  \"arguments\": {\n"
      for-each:x:@.arguments/*/arguments/*
         set-value:x:@.args
            strings.concat
               get-value:x:@.args
               .:"    \""
               get-name:x:@.dp/#
               .:"\":\""
               .:"[INPUT_VALUE]"
               .:"\",\n"
      set-value:x:@.args
         strings.concat
            strings.trim:x:@.args
               .:"\n,"
            .:"\n  }\n"
.completion
set-value:x:@.completion
   strings.concat
      .:"If the user is asking you to do perform an action associated with this function then respond with the following:\n\n"
      .:"___\n"
      .:"FUNCTION_INVOCATION[/misc/workflows/workflows/machine-learning/render-html-widget.hl]:\n{\n"
      .:"  \"filename\":\""
      get-value:x:@.arguments/*/filename
      .:"\"\n"
      get-value:x:@.args
      .:"}\n___\n"
log.info:x:@.completion

// Opening database.
data.connect:magic

   // Inserting our item.
   data.create
      table:ml_training_snippets
      values
         type:x:@.arguments/*/type
         prompt:x:@.arguments/*/prompt
         completion:x:@.completion
         meta:"FUNCTION_INVOCATION[/misc/workflows/workflows/machine-learning/render-html-widget.hl]"

   // Returning result to caller.
   yield
      id:x:@data.create
