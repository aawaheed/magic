
/*
 * Executes the specified [hyperlambda] with the specified [arguments].
 * 
 * Returns result of execution to caller.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory Hyperlambda to execute.
   hyperlambda:string

   // Optional arguments to supply to Hyperlambda code.
   arguments:*

// Ensuring user is root.
auth.ticket.verify:root

// Sanity checking invocation.
validators.mandatory:x:@.arguments/*/hyperlambda

// Converting to lambda object.
hyper2lambda:x:@.arguments/*/hyperlambda

// Parametrising execution.
add:x:./*/invoke
   get-nodes:x:@.arguments/*/arguments/*

// Executing Hyperlambda
invoke:x:@hyper2lambda

// Signaling frontend
sockets.signal:x:@.arguments/*/_session
   args
      type:floating_message
      floating_message:Hyperlambda code successfully executed
      floating_state:success

// Returning whatever our Hyperlambda returned.
if
   not-null:x:@invoke
   .lambda
      return-value:x:@invoke
else-if
   exists:x:@invoke/*
   .lambda
      return-nodes:x:@invoke/*
return
   message:Code did not return anything!
