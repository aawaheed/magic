
/*
 * Generate Hyperlambda code
 * 
 * This function allows you to generate Hyperlambda code.
 * The [prompt] argument must be the description of what code you want.
 */
.arguments

   // Injected by the framework.
   _session:string

   // Mandatory argument describing the Hyperlambda code you want to generate.
   prompt:string

   // Optional filename of where to save the Hyperlambda.
   filename:string

   // Optional value. If true, executes code immediately and returns result instead of code.
   immediate_mode:bool

// Ensuring user is root.
auth.ticket.verify:root

try
   add:x:./*/http.post/*/payload
      get-nodes:x:@.arguments/*/prompt
   .start
   set-value:x:-
      date.now
   http.post:"https://ainiro.io/magic/modules/hyperlambda-generator/chat"
      convert:true
      timeout:60
      payload
   .total
   set-value:x:-
      math.subtract
         date.now
         get-value:x:@.start
   if
      and
         exists:x:@.arguments/*/filename
         not-null:x:@.arguments/*/filename
      .lambda

         // Prepending slash unless specified by caller.
         if
            not
               strings.starts-with:x:@.arguments/*/filename
                  .:/
            .lambda
               set-value:x:@.arguments/*/filename
                  strings.concat
                     .:/
                     get-value:x:@.arguments/*/filename

         // Making sure we do not overwrite system files.
         if
            not
               or
                  strings.starts-with:x:@.arguments/*/filename
                     .:/etc/
                  strings.starts-with:x:@.arguments/*/filename
                     .:/modules/
            .lambda
               throw:"You can only save files to the '/modules/' and '/etc/' folders"
                  status:int:400
                  public:bool:true

         // Caller wants to save the file, so we sanity check it first.
         hyper2lambda:x:@http.post/*/content/*/result
            comments:true
         lambda2hyper:x:-/*
            comments:true
         io.file.save:x:@.arguments/*/filename
            get-value:x:@lambda2hyper
         unwrap:x:+/*/*
         add:x:@try/*/yield
            .
               saved:bool:true
               filename:x:@.arguments/*/filename

   // Signaling frontend
   sockets.signal:x:@.arguments/*/_session
      args
         type:floating_message
         floating_message:Hyperlambda successfully generated
         floating_state:success
   if
      and
         exists:x:@.arguments/*/immediate_mode
         eq:x:@.arguments/*/immediate_mode
            .:bool:true
      .lambda

         // Executing code and returning result instead of code.
         hyper2lambda:x:@http.post/*/content/*/result
         invoke:x:-
         if
            not-null:x:@invoke
            .lambda
               return-value:x:@invoke
         else-if
            exists:x:@invoke/*
            .lambda
               return-nodes:x:@invoke/*
         return
            message:Code did not return anything!

   yield
      code:x:@http.post/*/content/*/result
      time_spent:x:@.total

.catch
   lambda2hyper:x:../*
   log.error:x:@.arguments/*/message
      stack:x:@lambda2hyper
   throw:x:@.arguments/*/message
      status:int:502
      public:bool:true
